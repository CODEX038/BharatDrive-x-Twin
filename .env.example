# Copy to .env and fill only what you use. Everything is optional — offline mode needs no keys.
# Maps (optional)
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=
HERE_API_KEY=
# Weather (optional)
WEATHER_PROVIDER=mock
WEATHER_API_KEY=
# CCTV — authorized sources only (file|rtsp|hls|api)
CCTV_SOURCE_TYPE=file
CCTV_SOURCE_URL=
CCTV_USERNAME=
CCTV_PASSWORD=
# Privacy
RECORD_VIDEO=false
CONSENT_RECORDING=false
# Runtime
ALARM_PATH=assets/alarm.mp3
DASHBOARD_PORT=8765
DB_PATH=storage/bharatdrive.sqlite3
LANGUAGE=en
